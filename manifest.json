{
  "manifest_version": 2,
  "name": "yt-dlp Command Catcher",
  "version": "1.1",
  "description": "Intercepts m3u8 requests and generates yt-dlp commands with titles.",
  "permissions": [
    "webRequest",
    "<all_urls>",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Get yt-dlp command"
  }
}